# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS Finder / iCloud creates these when files are open in multiple editors.
# They shadow the real files and break the Next.js build (we hit this in CI).
*\ 2.ts
*\ 2.tsx
*\ 2.css
*\ 2.json
*\ 2.sql
*\ 3.ts
*\ 3.tsx
*\ 3.css
*\ 3.json
*\ 3.sql

# Supabase CLI temp/local artifacts
supabase/.temp
supabase/.branches
.claude/
